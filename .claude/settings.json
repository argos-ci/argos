{
  "permissions": {
    "allow": [
      "Bash(pnpm check-types *)",
      "Bash(pnpm lint *)",
      "Bash(pnpm check-format *)",
      "Bash(pnpm format *)",
      "Bash(pnpm codegen *)",
      "Bash(pnpm exec vitest *)",
      "Bash(pnpm knip *)",
      "Bash(pnpm knex *)",
      "Bash(pnpm db:check-structure)",
      "Bash(NODE_ENV=test pnpm db:reset)",
      "Bash(rtk vitest *)",
      "Bash(rtk prettier *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | { read -r f && [ -n \"$f\" ] && pnpm exec prettier --write --ignore-unknown \"$f\"; } 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
