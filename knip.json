{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "tags": ["-utility", "-graphqlType"],
  "workspaces": {
    "apps/backend": {
      "entry": [
        "src/processes/proc/*.ts",
        "src/build/bin/*.ts",
        "src/database/bin/*.ts",
        "src/database/testing/index.ts",
        "src/graphql/definitions/*.ts",
        "scripts/*.ts"
      ],
      "ignore": ["**/bin/**/*"],
      "ignoreDependencies": ["@argos/knex-scripts", "moment"]
    },
    "infra": {
      "entry": ["scripts/app.ts", "lambda/*.ts"],
      "ignore": ["cloudfront-functions/**/*"]
    },
    "apps/frontend": {}
  },
  "ignore": [
    "playwright.config.mts",
    "tests/truncate.setup.ts",
    "vitest/vitest.e2e.config.mts",
    "vitest/vitest.unit.config.mts"
  ],
  "ignoreBinaries": ["stripe", "ngrok", "op"],
  "ignoreDependencies": ["@graphql-codegen/add"]
}
