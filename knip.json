{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "tags": ["-utility", "-graphqlType"],
  "workspaces": {
    "apps/backend": {
      "entry": [
        "src/processes/proc/*.ts",
        "src/build/bin/*.ts",
        "src/database/bin/*.ts",
        "src/database/testing/index.ts",
        "src/graphql/definitions/*.ts",
        "scripts/*.ts"
      ],
      "ignore": ["**/bin/**/*"],
      "ignoreDependencies": ["@argos/knex-scripts", "moment"]
    },
    "infra": {
      "entry": ["bin/app.ts", "lambda/origin-request.ts"],
      "ignoreDependencies": ["esbuild"]
    },
    "apps/frontend": {
      "ignore": ["vite.config.mts"],
      "ignoreDependencies": [
        "@vitejs/plugin-react",
        "@sentry/vite-plugin",
        "@tailwindcss/vite"
      ],
      "vite": {
        "config": []
      }
    }
  },
  "ignore": [
    "playwright.config.mts",
    "tests/truncate.setup.ts",
    "vitest/vitest.e2e.config.mts",
    "vitest/vitest.unit.config.mts"
  ],
  "ignoreBinaries": ["stripe", "ngrok", "op", "tsx"]
}
